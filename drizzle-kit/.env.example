# drizzle-kit/.env.example — template for drizzle-kit test connection strings.
# Copy to drizzle-kit/.env (git-ignored) and adjust as needed. Ports must match
# the canonical compose/*.yml port bindings driven by compose/dockers.sh.

# Postgres (compose/postgres.yml — port 55433)
PG_CONNECTION_STRING=postgres://postgres:postgres@127.0.0.1:55433/drizzle

# Postgres version-pinned (compose/postgres16.yml, postgres17.yml, postgres18.yml, postgres-postgis.yml)
PG16_URL=postgres://postgres:postgres@127.0.0.1:54323/drizzle
PG17_URL=postgres://postgres:postgres@127.0.0.1:54324/drizzle
PG18_URL=postgres://postgres:postgres@127.0.0.1:54325/drizzle
POSTGIS_URL=postgres://postgres:postgres@127.0.0.1:54322/drizzle

# MySQL (compose/mysql.yml — port 3306)
MYSQL_CONNECTION_STRING=mysql://root:mysql@127.0.0.1:3306/drizzle

# MariaDB (compose/mariadb.yml — port 33306)
MARIADB_CONNECTION_STRING=mysql://root:mariadb@127.0.0.1:33306/drizzle

# Cockroach single-node (compose/cockroach.yml — port 26257). /defaultdb is intentional:
# fresh single-node cockroach has no `drizzle` DB; prepareClient creates per-worker DBs at runtime.
COCKROACH_CONNECTION_STRING=postgres://root@127.0.0.1:26257/defaultdb?sslmode=disable

# Cockroach 3-node (compose/cockroach-many.yml — ports 26260–26262). Uncomment for parallel cockroach tests.
# COCKROACH_CONNECTION_STRING=postgres://root@127.0.0.1:26260/defaultdb?sslmode=disable;postgres://root@127.0.0.1:26261/defaultdb?sslmode=disable;postgres://root@127.0.0.1:26262/defaultdb?sslmode=disable

# MSSQL (compose/mssql.yml — port 1433)
MSSQL_CONNECTION_STRING=mssql://SA:drizzle123PASSWORD!@127.0.0.1:1433?encrypt=true&trustServerCertificate=true

# SingleStore overload — drizzle-kit/tests/singlestore/mocks.ts reads MYSQL_CONNECTION_STRING
# (NOT a separate SINGLESTORE_CONNECTION_STRING). When running `pnpm test:singlestore`,
# swap MYSQL_CONNECTION_STRING above to the singlestore line below. This task does NOT
# refactor the test code — see CONTEXT §domain (out of scope).
# SingleStore (compose/singlestore.yml — port 33307)
# MYSQL_CONNECTION_STRING=mysql://root:singlestore@127.0.0.1:33307/
